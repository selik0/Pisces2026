# C# 游戏开发类库工程 .gitignore
# 只保留 .cs 源码文件和必要的 .dll 引用库

# ===== 构建输出 =====
[Bb]in/
[Oo]bj/
[Oo]ut/

# ===== Visual Studio =====
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# ===== 解决方案 & 项目文件（自动生成）=====
*.sln
# *.csproj  # 如需版本控制 csproj 请注释此行

# ===== 日志 & 临时文件 =====
*.log
*.tmp
*.temp
[Ll]ogs/
[Tt]emp/

# ===== NuGet =====
packages/
*.nupkg
*.snupkg
project.lock.json
project.assets.json
.nuget/

# ===== 调试符号（本地生成，无需提交）=====
*.pdb
*.mdb
*.ilk
*.map

# ===== 测试结果 =====
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx

# ===== ReSharper / Rider =====
_ReSharper*/
*.DotSettings.user
.idea/

# ===== OS 系统文件 =====
.DS_Store
Thumbs.db
Desktop.ini
